# Server
PORT=5000
NODE_ENV=production

# Database — MySQL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/fitnessapp"

# Auth
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,https://your-app.herokuapp.com
